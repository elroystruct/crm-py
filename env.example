# Optional locally. On Render, set these as real Environment Variables in the dashboard instead.
SIGNALWIRE_SPACE=your-space-name
SIGNALWIRE_PROJECT_ID=00000000-0000-0000-0000-000000000000
SIGNALWIRE_AUTH_TOKEN=your-auth-token
PORT=4400

# Leave unset locally to use SQLite (data/contacts.db).
# On Render, this gets filled in automatically if you use render.yaml with the attached Postgres DB.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
